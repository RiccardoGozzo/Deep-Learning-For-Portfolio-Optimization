    "    cost_rate     = COST_RATE,\n",
    "    n_repeats     = 5,\n",
    "    seed          = seed_value\n",
    ")\n",
    "\n",
    "plot_permutation_importance(imp_results, baseline_sharpe, \"Full_OOS\")"
