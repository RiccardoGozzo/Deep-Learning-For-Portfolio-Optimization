    "# ============================================================================\n",
    "# 6. DETAILED OUT-OF-SAMPLE PERFORMANCE EVALUATION\n",
    "# Comprehensive metric computation incorporating real-world trading frictions, \n",
    "# portfolio weight drift, and risk-adjusted return analysis.\n",
    "# ============================================================================\n",
    "final_model.eval()\n",
    "with torch.no_grad():\n",
    "    # Extract asset returns and risk-free rate from the test set tensor\n",
    "    targets = test_targets_full.squeeze(1) if test_targets_full.dim() == 3 else test_targets_full\n",
    "    asset_returns = targets[:, :-1]\n",
    "    rf_rate = targets[:, -1]\n",
    "    w_t = test_weights_full\n",
    "    \n",
    "    # 1. Gross Returns Calculation (pre-transaction costs)\n",
    "    gross_ret = torch.sum(w_t * asset_returns, dim=1)\n",
    "    \n",
    "    # 2. Drifted Weights and Turnover Calculation (Econometric Consistency)\n",
    "    # w_drifted[t] represents the allocation at the end of day t, distorted by asset price movements.\n",
    "    # This prevents underestimating turnover by assuming weights remain static intra-day.\n",
    "    w_drifted = w_t * (1 + asset_returns) / (1 + gross_ret.unsqueeze(1))\n",
    "    \n",
    "    # Turnover[t] is the absolute difference between today's target weights and yesterday's drifted weights\n",
    "    turnover = torch.zeros(w_t.shape[0], device=w_t.device)\n",
    "    turnover[1:] = torch.sum(torch.abs(w_t[1:] - w_drifted[:-1]), dim=1)\n",
    "    \n",
    "    # 3. Net Returns and Excess Returns (post-transaction costs)\n",
    "    costs = turnover * COST_RATE\n",
    "    net_ret = gross_ret - costs\n",
    "    net_excess_ret = net_ret - rf_rate\n",
    "    \n",
    "    # 4. Annualization (assuming 252 trading days per year)\n",
    "    ann_ret = torch.mean(net_excess_ret) * 252\n",
    "    ann_vol = torch.std(net_excess_ret) * np.sqrt(252)\n",
    "    sharpe = ann_ret / (ann_vol + 1e-8)\n",
    "    \n",
    "    # 5. Maximum Drawdown (MDD) Calculation\n",
    "    # Evaluated on the cumulative net return curve to measure the largest peak-to-trough drop\n",
    "    cum_net_ret = torch.cumsum(net_ret, dim=0)\n",
    "    running_max = torch.cummax(cum_net_ret, dim=0).values\n",
    "    drawdowns = running_max - cum_net_ret\n",
    "    max_dd = torch.max(drawdowns)\n",
    "    \n",
    "    # 6. Final Metrics Summary\n",
    "    avg_turnover = torch.mean(turnover)\n",
    "    \n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"FINAL TEST SET PERFORMANCE METRICS\")\n",
    "    print(\"=\"*50)\n",
    "    print(f\"{'Ann. Excess Return:':<25} {ann_ret.item()*100:>10.2f}%\")\n",
    "    print(f\"{'Ann. Volatility:':<25} {ann_vol.item()*100:>10.2f}%\")\n",
    "    print(f\"{'Sharpe Ratio:':<25} {sharpe.item():>10.4f}\")\n",
    "    print(f\"{'Max Drawdown:':<25} {max_dd.item()*100:>10.2f}%\")\n",
    "    print(f\"{'Avg Daily Turnover:':<25} {avg_turnover.item():>10.4f}\")\n",
    "    print(\"=\"*50)"
   ]
