     "text": [
      "\n",
      "==================================================\n",
      "MAXIMUM DIVERSIFICATION (MD) BENCHMARK RESULTS\n",
      "Estimation Window: 63 days | Cost Rate: 10 bps\n",
      "==================================================\n",
      "Ann. Excess Return  : 13.55%\n",
      "Ann. Volatility     : 11.22%\n",
      "Sharpe Ratio        : 1.2077\n",
      "Sortino Ratio       : 2.2188\n",
      "Max Drawdown        : 8.31%\n",
      "Avg Turnover        : 0.0192\n",
      "==================================================\n"
     ]
