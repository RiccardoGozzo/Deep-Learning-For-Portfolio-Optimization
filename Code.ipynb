    "ax.yaxis.set_major_formatter(mtick.PercentFormatter(1.0))\n",
    "ax.grid(axis='y', linestyle='--', alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
